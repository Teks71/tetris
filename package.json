{
  "name": "electron-tetris",
  "version": "1.0.0",
  "description": "Classic Tetris built with Electron and modern JavaScript best practices.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "start": "electron .",
    "lint": "eslint .",
    "package": "electron-builder"
  },
  "build": {
    "appId": "com.example.electrontetris",
    "productName": "Electron Tetris",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    }
  },
  "keywords": [
    "electron",
    "tetris",
    "game"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^29.3.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.56.0"
  }
}
